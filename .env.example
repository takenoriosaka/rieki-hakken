# ─────────────────────────────────────────────
# Gmail 設定
# ─────────────────────────────────────────────
# 送信元の Gmail アドレス
GMAIL_ADDRESS=your-gmail@gmail.com

# Google アカウントの「アプリパスワード」(16文字)
# 取得方法: Google アカウント → セキュリティ → 2段階認証 → アプリパスワード
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ─────────────────────────────────────────────
# 配信設定
# ─────────────────────────────────────────────
# 1人の生徒に1日何件まで送るか
DEALS_PER_STUDENT=10

# 同じ案件を最大何人の生徒に送るか（競合防止）
MAX_STUDENTS_PER_DEAL=3
